# Copy to .env and fill in real values. NEVER commit .env (it is git-ignored).

# --- Database (Postgres) ---
DATABASE_URL="postgresql://USER@localhost:5432/happybusride"

# --- NextAuth v5 ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- OTP / SMS (MSG91 — DLT registered SMS) ---
OTP_DEV_CODE="123456"            # dev-only fixed OTP; unset in production
MSG91_API_KEY=""                 # MSG91 Authkey (Console → API → Authkey); also verifies widget access tokens
MSG91_TEMPLATE_ID=""             # OTP template ID (sender ID is bound to the template on MSG91)
# OTP widget (client-side SDK, MSG91 Console → OTP → Widgets). NEXT_PUBLIC_
# means inlined into the browser bundle — public by design. When unset, the
# app falls back to the server-side send/verify flow above. In the Amplify
# Console these are named MSG91_WIDGET_ID / MSG91_TOKEN_AUTH (no NEXT_ prefix,
# Amplify filters NEXT_* vars); amplify.yml maps them at build time.
NEXT_PUBLIC_MSG91_WIDGET_ID=""
NEXT_PUBLIC_MSG91_TOKEN_AUTH=""

# --- WhatsApp (Meta Cloud API) ---
# Phone Number ID from Meta Developer Console → WhatsApp → API Setup
META_WHATSAPP_PHONE_NUMBER_ID=""
# Permanent System User access token from Meta Business Manager
META_WHATSAPP_ACCESS_TOKEN=""
# Name of the approved Authentication template (category: AUTHENTICATION)
META_WHATSAPP_OTP_TEMPLATE_NAME="happybusride_otp"

# --- Rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- AWS (S3 uploads + SES email) ---
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""
SES_FROM_EMAIL=""
AWS_ACCESS_KEY_ID=""             # or use an instance/role credential chain
AWS_SECRET_ACCESS_KEY=""

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Anthropic ---
ANTHROPIC_API_KEY=""

# --- Cron (outbox relay endpoint auth) ---
CRON_SECRET=""

# --- Misc ---
UPLOAD_DIR="./uploads"
NODE_ENV="development"
