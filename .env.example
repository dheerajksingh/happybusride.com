# Copy to .env and fill in real values. NEVER commit .env (it is git-ignored).

# --- Database (Postgres) ---
DATABASE_URL="postgresql://USER@localhost:5432/happybusride"

# --- NextAuth v5 ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- OTP / SMS (MSG91) ---
OTP_DEV_CODE="123456"            # dev-only fixed OTP; unset in production
MSG91_API_KEY=""
MSG91_SENDER_ID=""
MSG91_TEMPLATE_ID=""

# --- Rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- AWS (S3 uploads + SES email) ---
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""
SES_FROM_EMAIL=""
AWS_ACCESS_KEY_ID=""             # or use an instance/role credential chain
AWS_SECRET_ACCESS_KEY=""

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Anthropic ---
ANTHROPIC_API_KEY=""

# --- Cron (outbox relay endpoint auth) ---
CRON_SECRET=""

# --- Misc ---
UPLOAD_DIR="./uploads"
NODE_ENV="development"
